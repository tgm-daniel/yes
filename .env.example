# Admin credentials (JSON array of {username, password} pairs)
# Generate with: python3 -c "import json; print(json.dumps([{'username':'admin','password':'your-secure-password'}]))"
ADMIN_USERS=[{"username":"admin","password":"your-secure-password"}]

# JWT secret (generate a random string!)
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=generate-a-random-secret-here

# Database URL (defaults to SQLite if not set)
# For PostgreSQL on Render:
# DATABASE_URL=postgresql://user:pass@host:5432/db
